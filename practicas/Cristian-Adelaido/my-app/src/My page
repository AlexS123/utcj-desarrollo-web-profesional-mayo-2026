<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Menú Fixed Profesional</title>

    <!-- ICONOS -->
    <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"/>

    <style>

        *{
            margin:0;
            padding:0;
            box-sizing:border-box;
            font-family:Arial, Helvetica, sans-serif;
        }

        body{
            background:#f5f5f5;
        }

        /* =========================
           HEADER / NAVBAR
        ==========================*/

        header{
            width:100%;
            position:fixed;
            top:0;
            left:0;
            z-index:1000;
            background:#0f172a;
            box-shadow:0 2px 10px rgba(0,0,0,.3);
        }

        .navbar{
            width:90%;
            max-width:1400px;
            margin:auto;
            display:flex;
            justify-content:space-between;
            align-items:center;
            padding:18px 0;
        }

        /* LOGO */

        .logo{
            color:white;
            font-size:28px;
            font-weight:bold;
            letter-spacing:2px;
            cursor:pointer;
        }

        .logo span{
            color:#38bdf8;
        }

        /* MENU */

        .nav-links{
            display:flex;
            list-style:none;
            gap:25px;
            align-items:center;
        }

        .nav-links li{
            position:relative;
        }

        .nav-links a{
            color:white;
            text-decoration:none;
            font-size:16px;
            transition:.3s;
            padding:10px;
        }

        .nav-links a:hover{
            color:#38bdf8;
        }

        /* BOTON */

        .btn-contacto{
            background:#38bdf8;
            color:white !important;
            padding:10px 18px;
            border-radius:30px;
            transition:.3s;
        }

        .btn-contacto:hover{
            background:#0ea5e9;
        }

        /* DROPDOWN */

        .dropdown{
            position:absolute;
            top:45px;
            left:0;
            background:white;
            width:220px;
            border-radius:10px;
            display:none;
            overflow:hidden;
            box-shadow:0 5px 20px rgba(0,0,0,.2);
        }

        .dropdown a{
            color:#111;
            display:block;
            padding:15px;
        }

        .dropdown a:hover{
            background:#38bdf8;
            color:white;
        }

        .nav-links li:hover .dropdown{
            display:block;
        }

        /* HERO */

        .hero{
            height:100vh;
            background:linear-gradient(rgba(0,0,0,.5), rgba(0,0,0,.5)),
            url('https://images.unsplash.com/photo-1498050108023-c5249f4df085?q=80&w=1200');
            background-size:cover;
            background-position:center;
            display:flex;
            justify-content:center;
            align-items:center;
            text-align:center;
            color:white;
            padding:20px;
        }

        .hero-content h1{
            font-size:60px;
            margin-bottom:20px;
        }

        .hero-content p{
            font-size:20px;
            max-width:700px;
            margin:auto;
            margin-bottom:30px;
        }

        .hero-content button{
            padding:15px 30px;
            border:none;
            border-radius:30px;
            background:#38bdf8;
            color:white;
            font-size:18px;
            cursor:pointer;
            transition:.3s;
        }

        .hero-content button:hover{
            background:#0ea5e9;
            transform:scale(1.05);
        }

        /* TARJETAS */

        .cards{
            width:90%;
            max-width:1200px;
            margin:80px auto;
            display:grid;
            grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
            gap:25px;
        }

        .card{
            background:white;
            padding:30px;
            border-radius:20px;
            text-align:center;
            box-shadow:0 5px 15px rgba(0,0,0,.1);
            transition:.3s;
        }

        .card:hover{
            transform:translateY(-10px);
        }

        .card i{
            font-size:45px;
            color:#38bdf8;
            margin-bottom:20px;
        }

        .card h3{
            margin-bottom:15px;
        }

        /* FOOTER */

        footer{
            background:#0f172a;
            color:white;
            text-align:center;
            padding:25px;
            margin-top:50px;
        }

        /* RESPONSIVE */

        .menu-toggle{
            display:none;
            color:white;
            font-size:28px;
            cursor:pointer;
        }

        @media(max-width:900px){

            .menu-toggle{
                display:block;
            }

            .nav-links{
                position:absolute;
                top:80px;
                left:0;
                width:100%;
                background:#0f172a;
                flex-direction:column;
                display:none;
                padding:20px 0;
            }

            .nav-links.active{
                display:flex;
            }

            .dropdown{
                position:static;
                width:100%;
                background:#1e293b;
                box-shadow:none;
            }

            .dropdown a{
                color:white;
            }

            .hero-content h1{
                font-size:40px;
            }

            .hero-content p{
                font-size:16px;
            }

        }

    </style>
</head>
<body>

    <!-- HEADER -->
    <header>

        <nav class="navbar">

            <div class="logo">
                My<span>Site</span>
            </div>

            <ul class="nav-links" id="menu">

                <li><a href="#">Inicio</a></li>

                <li>
                    <a href="#">Servicios <i class="fa-solid fa-caret-down"></i></a>

                    <div class="dropdown">
                        <a href="#">Diseño Web</a>
                        <a href="#">Desarrollo App</a>
                        <a href="#">Marketing</a>
                        <a href="#">SEO</a>
                    </div>
                </li>

                <li><a href="#">Nosotros</a></li>

                <li><a href="#">Portafolio</a></li>

                <li><a href="#">Blog</a></li>

                <li><a href="#">Contacto</a></li>

                <li>
                    <a href="#" class="btn-contacto">
                        <i class="fa-solid fa-phone"></i> Llamar
                    </a>
                </li>

            </ul>

            <!-- BOTON MENU MOVIL -->
            <div class="menu-toggle" id="toggle">
                <i class="fa-solid fa-bars"></i>
            </div>

        </nav>

    </header>

    <!-- HERO -->
    <section class="hero">

        <div class="hero-content">

            <h1>Bienvenido a Mi Página</h1>

            <p>
                Un diseño moderno con menú fixed,
                responsive, dropdowns y efectos profesionales.
            </p>

            <button>Comenzar</button>

        </div>

    </section>

    <!-- TARJETAS -->
    <section class="cards">

        <div class="card">
            <i class="fa-solid fa-code"></i>
            <h3>Desarrollo</h3>
            <p>Creación de páginas modernas y responsivas.</p>
        </div>

        <div class="card">
            <i class="fa-solid fa-mobile-screen"></i>
            <h3>Apps</h3>
            <p>Aplicaciones móviles para Android y iOS.</p>
        </div>

        <div class="card">
            <i class="fa-solid fa-chart-line"></i>
            <h3>Marketing</h3>
            <p>Estrategias digitales para crecer tu negocio.</p>
        </div>

    </section>

    <!-- FOOTER -->
    <footer>
        © 2026 - Página Profesional | Diseñada por Cristian
    </footer>

    <!-- SCRIPT -->
    <script>

        const toggle = document.getElementById('toggle');
        const menu = document.getElementById('menu');

        toggle.addEventListener('click', () => {
            menu.classList.toggle('active');
        });

    </script>

</body>
</html>